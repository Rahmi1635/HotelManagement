<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotelreservationsystem.ui.controller.CustomerDashboardController">
    <children>
        <AnchorPane prefHeight="500.0" prefWidth="850.0">
            <children>

                <AnchorPane layoutX="0.0" prefHeight="500.0" prefWidth="300.0" styleClass="left-form" stylesheets="@cssFile/logIn.css">
                    <children>
                        <ImageView fitHeight="202.0" fitWidth="174.0" layoutX="70.0" layoutY="124.0">
                            <image>
                                <Image url="@pictures/hotel3.jpg" />
                            </image>
                        </ImageView>

                        <Label layoutX="45.0" layoutY="360.0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Customer Dashboard">
                            <font>
                                <Font name="Tahoma" size="34.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>

                <AnchorPane layoutX="300.0" prefHeight="500.0" prefWidth="550.0" styleClass="white-bg" stylesheets="@cssFile/logIn.css">
                    <children>

                        <Button layoutX="490.0" layoutY="10.0" mnemonicParsing="false" onAction="#closeForm" prefHeight="26.0" prefWidth="50.0" styleClass="close" stylesheets="@cssFile/logIn.css" text="X" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0" />

                        <ImageView fitHeight="55.0" fitWidth="62.0" layoutX="244.0" layoutY="40.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@pictures/user.png" />
                            </image>
                        </ImageView>

                        <Label layoutX="190.0" layoutY="100.0" text="Welcome, Customer" textFill="#3e6bae" wrapText="true">
                            <font>
                                <Font name="Segoe UI" size="26.0" />
                            </font>
                        </Label>

                        <Button fx:id="btnProfile" layoutX="170.0" layoutY="170.0" mnemonicParsing="false" onAction="#openProfile" prefHeight="42.0" prefWidth="210.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="My Profile" />

                        <Button fx:id="btnSearchRooms" layoutX="170.0" layoutY="225.0" mnemonicParsing="false" onAction="#openRoomSearch" prefHeight="42.0" prefWidth="210.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Search Rooms" />

                        <Button fx:id="btnMyReservations" layoutX="170.0" layoutY="280.0" mnemonicParsing="false" onAction="#openMyReservations" prefHeight="42.0" prefWidth="210.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="My Reservations" />

                        <Button fx:id="btnPastStays" layoutX="170.0" layoutY="335.0" mnemonicParsing="false" onAction="#openPastStays" prefHeight="42.0" prefWidth="210.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Past Stays" />

                        <Button fx:id="btnLogout" layoutX="170.0" layoutY="400.0" mnemonicParsing="false" onAction="#logout" prefHeight="42.0" prefWidth="210.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Logout" />

                    </children>
                </AnchorPane>

            </children>
        </AnchorPane>
    </children>
</StackPane>
