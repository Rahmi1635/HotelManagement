<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotelreservationsystem.ui.controller.PastStaysController">

    <!-- TOP -->
    <top>
        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Past Stays" BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>
        </Label>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <TableView fx:id="pastStaysTable" prefHeight="500.0" prefWidth="572.0">
                <columns>
                    <TableColumn fx:id="roomColumn" prefWidth="120" text="Room" />
                    <TableColumn fx:id="checkInColumn" prefWidth="150" text="Check-In" />
                    <TableColumn fx:id="checkOutColumn" prefWidth="150" text="Check-Out" />
                    <TableColumn fx:id="priceColumn" prefWidth="150" text="Total Price" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleBack" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" text="Back" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
