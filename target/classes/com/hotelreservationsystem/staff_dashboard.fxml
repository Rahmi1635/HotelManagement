<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotelreservationsystem.ui.controller.StaffDashboardController">
    <children>
        <AnchorPane prefHeight="500.0" prefWidth="950.0">
            <children>

                <AnchorPane layoutX="0.0" prefHeight="500.0" prefWidth="300.0" styleClass="left-form" stylesheets="@cssFile/logIn.css">
                    <children>
                        <ImageView fitHeight="202.0" fitWidth="174.0" layoutX="70.0" layoutY="124.0">
                            <image>
                                <Image url="@pictures/hotel3.jpg" />
                            </image>
                        </ImageView>

                        <Label layoutX="55.0" layoutY="360.0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Staff Dashboard">
                            <font>
                                <Font name="Tahoma" size="34.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>

                <AnchorPane layoutX="300.0" prefHeight="500.0" prefWidth="650.0" styleClass="white-bg" stylesheets="@cssFile/logIn.css">
                    <children>

                        <Button layoutX="590.0" layoutY="10.0" mnemonicParsing="false" onAction="#closeForm" prefHeight="26.0" prefWidth="50.0" styleClass="close" stylesheets="@cssFile/logIn.css" text="X" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0" />

                        <ImageView fitHeight="55.0" fitWidth="62.0" layoutX="294.0" layoutY="40.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@pictures/user.png" />
                            </image>
                        </ImageView>

                        <Label layoutX="260.0" layoutY="100.0" text="Welcome, Staff" textFill="#3e6bae" wrapText="true">
                            <font>
                                <Font name="Segoe UI" size="26.0" />
                            </font>
                        </Label>

                        <Button fx:id="btnNewCustomer" layoutX="220.0" layoutY="170.0" mnemonicParsing="false" onAction="#openNewCustomer" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Register New Customer" />

                        <Button fx:id="btnListCustomers" layoutX="220.0" layoutY="220.0" mnemonicParsing="false" onAction="#openCustomerList" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="List / Search Customers" />

                        <Button fx:id="btnNewRoom" layoutX="220.0" layoutY="270.0" mnemonicParsing="false" onAction="#openNewRoom" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Add New Room" />

                        <Button fx:id="btnReservations" layoutX="220.0" layoutY="320.0" mnemonicParsing="false" onAction="#openReservationList" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Reservations (List / Filter)" />

                        <Button fx:id="btnCheckInOut" layoutX="220.0" layoutY="370.0" mnemonicParsing="false" onAction="#openCheckInOut" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Check-In / Check-Out" />

                        <Button fx:id="btnLogout" layoutX="220.0" layoutY="430.0" mnemonicParsing="false" onAction="#logout" prefHeight="40.0" prefWidth="240.0" styleClass="login-btn" stylesheets="@cssFile/logIn.css" text="Logout" />

                    </children>
                </AnchorPane>

            </children>
        </AnchorPane>
    </children>
</StackPane>
