<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.hotelreservationsystem.ui.controller.RegisterCustomerController">

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="left-form" stylesheets="@cssFile/logIn.css">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="Hotel Reservation " textFill="WHITE">
                <font>
                    <Font size="22" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Personnel Panel" textFill="#ecf0f1" />
         <Button mnemonicParsing="false" onAction="#closeForm" prefHeight="26.0" prefWidth="45.0" styleClass="close" stylesheets="@cssFile/logIn.css" text="X" />
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <HBox spacing="30">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <!-- CUSTOMER REGISTRATION PANEL -->
            <VBox prefWidth="350" spacing="12" style="-fx-background-color: #ecf0f1; -fx-background-radius: 10;">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>
                <Label text="New Customer Registration">
                    <font>
                        <Font size="16" />
                    </font>
                </Label>

                <TextField fx:id="firstNameField" promptText="First Name" />
                <TextField fx:id="lastNameField" promptText="Last Name" />
                <TextField fx:id="emailField" promptText="Email" />
                <TextField fx:id="phoneField" promptText="Phone Number" />
                <TextField fx:id="identityNumberField" promptText="Identity Number" />

                <Button onAction="#handleCreateCustomer" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Create Customer" />
            </VBox>

            <!-- RESERVATION PANEL -->
            <VBox prefWidth="400" spacing="12" style="-fx-background-color: #ecf0f1; -fx-background-radius: 10;">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>
                <Label text="Create Reservation">
                    <font>
                        <Font size="16" />
                    </font>
                </Label>

                <ComboBox fx:id="customerComboBox" promptText="Select Customer" />

                <HBox spacing="10">
                    <DatePicker fx:id="checkInDatePicker" promptText="Check-in Date" />
                    <DatePicker fx:id="checkOutDatePicker" promptText="Check-out Date" />
                </HBox>

                <ComboBox fx:id="roomTypeComboBox" promptText="Select Room Type" />
                <ComboBox fx:id="roomNumberComboBox" promptText="Select Room" />

                <Button onAction="#handleCreateReservation" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Create Reservation" />
            </VBox>
        </HBox>
    </center>

    <!-- BOTTOM INFO -->
    <bottom>
        <HBox alignment="CENTER">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="© 2025 Hotel Management System" textFill="#7f8c8d" />
        </HBox>
    </bottom>

</BorderPane>
