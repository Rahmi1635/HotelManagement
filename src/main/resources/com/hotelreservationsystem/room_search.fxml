<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600" prefWidth="1000" style="-fx-background-color: linear-gradient(to bottom right, #5A4FCF, #8E44AD);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotelreservationsystem.ui.controller.RoomSearchController">


    <!-- SOL PANEL : ARAMA KRİTERLERİ -->
    <VBox layoutX="30.0" layoutY="46.0" prefWidth="300" spacing="15" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 16;" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="46.0">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>


        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Search Rooms" />


        <Label text="Check-in Date" />
        <DatePicker fx:id="checkInDatePicker" />


        <Label text="Check-out Date" />
        <DatePicker fx:id="checkOutDatePicker" />


        <Label text="Room Type" />
        <ComboBox fx:id="roomTypeComboBox" promptText="Select room type" />


        <Button onAction="#roomSearch" prefHeight="40" style="-fx-background-radius: 20; -fx-font-size: 14px;" text="Search" />
    </VBox>


    <!-- SAĞ PANEL : SONUÇLAR -->
    <VBox layoutX="353.0" layoutY="46.0" prefHeight="529.0" prefWidth="600.0" spacing="10" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 16;" AnchorPane.bottomAnchor="25.200000000000045" AnchorPane.leftAnchor="353.0" AnchorPane.rightAnchor="47.0" AnchorPane.topAnchor="46.0">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>


        <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Available Rooms" />


        <TableView fx:id="roomTableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="roomTypeColumn" prefWidth="150" text="Room Type" />
                <TableColumn fx:id="priceColumn" prefWidth="120" text="Price" />
                <TableColumn fx:id="availabilityColumn" prefWidth="150" text="Availability" />
                <TableColumn fx:id="actionColumn" prefWidth="150" text="Action" />
            </columns>
        </TableView>


    </VBox>
   <Button layoutX="934.0" layoutY="14.0" mnemonicParsing="false" onAction="#closeForm" prefHeight="26.0" prefWidth="44.0" styleClass="close" stylesheets="@cssFile/logIn.css" text="X" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="3.0" />


</AnchorPane>
